# netadmin-mcp environment variables
# -----------------------------------
# Copy this file to `.env` and edit. `.env` is git-ignored; this template is not.
#   cp .env.example .env
#
# Every value below is OPTIONAL — the server boots fine with no .env at all and
# falls back to the defaults shown. Real shell environment variables take
# precedence over .env entries.

# --- binaries (override if nmap/curl/bash aren't on PATH or you want a specific build) ---
# NETADMIN_MCP_NMAP_BIN=/usr/bin/nmap
# NETADMIN_MCP_CURL_BIN=/usr/bin/curl
# NETADMIN_MCP_BASH_BIN=/bin/bash

# --- nmap_scan ---
# NETADMIN_MCP_NMAP_MAX_TIMEOUT=300       # hard ceiling, seconds per nmap run
# NETADMIN_MCP_NMAP_DEFAULT_TIMEOUT=120   # default nmap timeout, seconds
# NETADMIN_MCP_NMAP_TOP_PORTS=100         # default --top-ports when no ports given

# --- bash_exec (guarded shell) ---
# NETADMIN_MCP_BASH_MAX_TIMEOUT=120          # hard ceiling, seconds per bash invocation
# NETADMIN_MCP_BASH_DEFAULT_TIMEOUT=30       # default wall-clock timeout, seconds
# NETADMIN_MCP_BASH_MAX_OUTPUT_BYTES=262144  # 256 KB cap on captured stdout/stderr
# Command allowlist (space/comma separated). Setting this REPLACES the default set
# (nmap, nc, ncat, ping, dig, curl, printf, sleep, cat, grep, ...).
# NETADMIN_MCP_ALLOWED_CMDS=nmap nc ping printf sleep curl dig
# Disable the allowlist entirely (only do this in an isolated/container env):
# NETADMIN_MCP_BASH_ALLOWLIST_DISABLED=0

# --- web (curl) safety limits ---
# NETADMIN_MCP_WEB_DEFAULT_TIMEOUT=15   # default whole-request timeout, seconds
# NETADMIN_MCP_WEB_MAX_TIMEOUT=60       # hard ceiling, seconds
# NETADMIN_MCP_WEB_MAX_REDIRECTS=10     # max redirects to follow
# NETADMIN_MCP_WEB_MAX_BYTES=5000000    # 5 MB hard cap on downloaded body
# NETADMIN_MCP_USER_AGENT=netadmin-mcp/1.0 (+curl)
