# netcat-mcp environment variables
# -----------------------------------
# Copy this file to `.env` and edit. `.env` is git-ignored; this template is not.
#   cp .env.example .env
#
# Every value below is OPTIONAL — the server boots fine with no .env at all and
# falls back to the defaults shown. Real shell environment variables take
# precedence over .env entries.

# --- binaries (override if nc/curl aren't on PATH or you want a specific build) ---
# NETCAT_MCP_NC_BIN=/usr/bin/nc
# NETCAT_MCP_CURL_BIN=/usr/bin/curl

# --- netcat safety limits ---
# NETCAT_MCP_MAX_TIMEOUT=15           # hard ceiling, seconds per nc connection
# NETCAT_MCP_DEFAULT_TIMEOUT=4        # default per-connection timeout, seconds
# NETCAT_MCP_MAX_PAYLOAD_BYTES=8192   # cap on raw_send_recv payload
# NETCAT_MCP_MAX_RECV_BYTES=65536     # cap on captured reply size

# --- web (curl) safety limits ---
# NETCAT_MCP_WEB_DEFAULT_TIMEOUT=15   # default whole-request timeout, seconds
# NETCAT_MCP_WEB_MAX_TIMEOUT=60       # hard ceiling, seconds
# NETCAT_MCP_WEB_MAX_REDIRECTS=10     # max redirects to follow
# NETCAT_MCP_WEB_MAX_BYTES=5000000    # 5 MB hard cap on downloaded body
# NETCAT_MCP_USER_AGENT=netcat-mcp/1.0 (+curl)
